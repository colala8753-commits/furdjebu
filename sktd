-- ===== 9. AUTO TARGET =====
local function updateAutoTarget(state)
    if autoTargetConnection then
        autoTargetConnection:Disconnect()
        autoTargetConnection = nil
    end
    autoTargetEnabled = state
    if state then
        autoTargetConnection = RunService.Heartbeat:Connect(function()
            if autoTargetEnabled and character then
                local target = nil
                local dist = math.huge
                for _, v in pairs(game.Players:GetPlayers()) do
                    if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        local d = (root.Position - v.Character.HumanoidRootPart.Position).Magnitude
                        if d < dist then
                            dist = d
                            target = v
                        end
                    end
                end
                if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    root.CFrame = CFrame.lookAt(root.Position, target.Character.HumanoidRootPart.Position)
                end
            end
        end)
    end
end

