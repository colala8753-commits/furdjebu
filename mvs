-- ===== ESP (ОПТИМИЗИРОВАН - ОБНОВЛЕНИЕ РАЗ В 5 КАДРОВ) =====
local function updateESP(state)
    espEnabled = state
    
    if espUpdateConnection then
        espUpdateConnection:Disconnect()
        espUpdateConnection = nil
    end
    
    if state then
        espUpdateConnection = RunService.RenderStepped:Connect(function()
            espUpdateCounter = espUpdateCounter + 1
            if espUpdateCounter % 5 ~= 0 then return end
            
            local currentPlayers = {}
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local humanoidCheck = v.Character:FindFirstChild("Humanoid")
                    if humanoidCheck and humanoidCheck.Health > 0 then
                        currentPlayers[v] = true
                    end
                end
            end
            
            -- Удаляем старые Highlight для игроков которых нет
            for v, hl in pairs(espHighlights) do
                if not currentPlayers[v] then
                    pcall(function() hl:Destroy() end)
                    espHighlights[v] = nil
                end
            end
            
            -- Создаем новые Highlight
            local myTeam = nil
            if player.Team then
                myTeam = player.Team
            end
            
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local humanoidCheck = v.Character:FindFirstChild("Humanoid")
                    if humanoidCheck and humanoidCheck.Health > 0 then
                        if not espHighlights[v] then
                            local color = nil
                            local transparency = 0.3
                            
                            if myTeam and v.Team then
                                if v.Team == myTeam then
                                    color = Color3.fromRGB(0, 255, 50)
                                else
                                    color = Color3.fromRGB(255, 0, 0)
                                end
                            else
                                color = Color3.fromRGB(200, 200, 200)
                                transparency = 0.5
                            end
                            
                            local hl = Instance.new("Highlight")
                            hl.Parent = v.Character
                            hl.Adornee = v.Character
                            hl.FillColor = color
                            hl.FillTransparency = transparency
                            hl.OutlineColor = color
                            hl.OutlineTransparency = 0.1
                            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                            espHighlights[v] = hl
                        end
                    end
                end
            end
        end)
    else
        for _, hl in pairs(espHighlights) do
            pcall(function() hl:Destroy() end)
        end
        espHighlights = {}
    end
end

-- ===== СМАРТ АИМБОТ (НЕ ЧЕРЕЗ СТЕНЫ + АВТОВЫСТРЕЛ) =====
local function updateAimbot(state)
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
    aimbotEnabled = state
    
    if state then
        aimbotConnection = RunService.Heartbeat:Connect(function()
            if aimbotEnabled and character and root then
                local target = nil
                local dist = math.huge
                local myTeam = player.Team
                
                -- Находим видимого врага
                for _, v in pairs(game.Players:GetPlayers()) do
                    if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        local humanoidCheck = v.Character:FindFirstChild("Humanoid")
                        if humanoidCheck and humanoidCheck.Health > 0 then
                            if myTeam and v.Team then
                                if v.Team ~= myTeam then
                                    -- Проверяем видимость
                                    if isVisible(v.Character.HumanoidRootPart) then
                                        local d = (root.Position - v.Character.HumanoidRootPart.Position).Magnitude
                                        if d < dist then
                                            dist = d
                                            target = v
                                        end
                                    end
                                end
                            else
                                if isVisible(v.Character.HumanoidRootPart) then
                                    local d = (root.Position - v.Character.HumanoidRootPart.Position).Magnitude
                                    if d < dist then
                                        dist = d
                                        target = v
                                    end
                                end
                            end
                        end
                    end
                end
                
                if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    local targetPos = target.Character.HumanoidRootPart.Position
                    
                    -- Наводим камеру
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
                    
                    -- Автоматический выстрел, если цель видна
                    if isVisible(target.Character.HumanoidRootPart) then
                        pcall(function()
                            local remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                            if remotes then
                                -- Пробуем разные варианты выстрела
                                if remotes:FindFirstChild("Gun") then
                                    remotes.Gun:FireServer(target.Character.HumanoidRootPart)
                                elseif remotes:FindFirstChild("Shoot") then
                                    remotes.Shoot:FireServer(target.Character)
                                elseif remotes:FindFirstChild("Fire") then
                                    remotes.Fire:FireServer(target.Character.HumanoidRootPart)
                                end
                            end
                        end)
                    end
                end
            end
        end)
    end
end

