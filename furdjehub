-- Переменная для хранения загруженного скрипта
local loadedScript = nil
local isScriptRunning = false

-- ===== ФУНКЦИЯ ЗАГРУЗКИ СКРИПТА =====
local function loadScript(scriptCode)
    if isScriptRunning then
        pcall(function()
            if loadedScript then
                loadedScript = nil
            end
        end)
        isScriptRunning = false
    end
    
    if scriptCode and scriptCode ~= "" then
        local success, err = pcall(function()
            local func = loadstring(scriptCode)
            if func then
                loadedScript = func
                func()
                isScriptRunning = true
                print("✅ Скрипт успешно загружен!")
            else
                error("Не удалось скомпилировать скрипт")
            end
        end)
        
        if not success then
            warn("❌ Ошибка загрузки скрипта: " .. tostring(err))
            showNotification("❌ Ошибка загрузки скрипта!", Color3.fromRGB(200, 40, 40))
        end
    else
        showNotification("⚠️ Скрипт для этого режима не добавлен", Color3.fromRGB(200, 150, 40))
    end
end

-- ===== УВЕДОМЛЕНИЯ =====
local function showNotification(text, color)
    color = color or Color3.fromRGB(0, 150, 70)
    local notif = Instance.new("ScreenGui")
    notif.Name = "Notification"
    notif.Parent = player:WaitForChild("PlayerGui")
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 400, 0, 60)
    frame.Position = UDim2.new(0.5, -200, 0.5, -30)
    frame.BackgroundColor3 = color
    frame.Parent = notif
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = frame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 16
    label.Font = Enum.Font.GothamBold
    label.BackgroundTransparency = 1
    label.Parent = frame
    
    task.wait(2.5)
    notif:Destroy()
end

