-- Проверка, находится ли мышь над GUI
local function isMouseOverGUI()
    local mousePos = Vector2.new(mouse.X, mouse.Y)
    
    -- Проверяем главное окно
    if mainFrame.Visible then
        local absPos = mainFrame.AbsolutePosition
        local absSize = mainFrame.AbsoluteSize
        if mousePos.X >= absPos.X and mousePos.X <= absPos.X + absSize.X and
           mousePos.Y >= absPos.Y and mousePos.Y <= absPos.Y + absSize.Y then
            return true
        end
    end
    
    -- Проверяем кнопку сворачивания
    local toggleAbsPos = toggleBtn.AbsolutePosition
    local toggleAbsSize = toggleBtn.AbsoluteSize
    if mousePos.X >= toggleAbsPos.X and mousePos.X <= toggleAbsPos.X + toggleAbsSize.X and
       mousePos.Y >= toggleAbsPos.Y and mousePos.Y <= toggleAbsPos.Y + toggleAbsSize.Y then
        return true
    end
    
    return false
end

-- Запись действий
local function recordAction(actionType, data)
    local currentTime = tick() - startTime
    table.insert(recordedActions, {
        time = currentTime,
        type = actionType,
        data = data
    })
    updateUI()
end

-- Старт записи
function startRecording()
    if isPlaying then
        stopPlayback()
    end
    
    recordedActions = {}
    startTime = tick()
    isRecording = true
    recordBtn.Text = "⏹ СТОП"
    recordBtn.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
    statusLabel.Text = "🔴 ЗАПИСЬ..."
    statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    updateUI()
    
    -- Запись кликов мыши (с проверкой на GUI)
    recordingConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if not isRecording then return end
        
        -- Игнорируем клики по GUI
        if isMouseOverGUI() then
            return
        end
        
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            recordAction("click", {x = mouse.X, y = mouse.Y, button = "left"})
        elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
            recordAction("click", {x = mouse.X, y = mouse.Y, button = "right"})
        elseif input.KeyCode == Enum.KeyCode.Space then
            recordAction("jump", {})
        elseif input.KeyCode == Enum.KeyCode.W then
            recordAction("key", {key = "W", state = "down"})
        elseif input.KeyCode == Enum.KeyCode.A then
            recordAction("key", {key = "A", state = "down"})
        elseif input.KeyCode == Enum.KeyCode.S then
            recordAction("key", {key = "S", state = "down"})
        elseif input.KeyCode == Enum.KeyCode.D then
            recordAction("key", {key = "D", state = "down"})
        elseif input.KeyCode == Enum.KeyCode.LeftShift then
            recordAction("key", {key = "Shift", state = "down"})
        end
    end)
    
    -- Запись отпускания клавиш
    local releaseConnection = UserInputService.InputEnded:Connect(function(input)
        if not isRecording then return end
        
        -- Игнорируем если курсор над GUI
        if isMouseOverGUI() then
            return
        end
        
        if input.KeyCode == Enum.KeyCode.W then
            recordAction("key", {key = "W", state = "up"})
        elseif input.KeyCode == Enum.KeyCode.A then
            recordAction("key", {key = "A", state = "up"})
        elseif input.KeyCode == Enum.KeyCode.S then
            recordAction("key", {key = "S", state = "up"})
        elseif input.KeyCode == Enum.KeyCode.D then
            recordAction("key", {key = "D", state = "up"})
        elseif input.KeyCode == Enum.KeyCode.LeftShift then
            recordAction("key", {key = "Shift", state = "up"})
        end
    end)
    
    -- Запись движения мыши (с проверкой на GUI)
    local mouseConnection = RunService.RenderStepped:Connect(function()
        if isRecording and mouse then
            -- Записываем только если мышь не над GUI
            if not isMouseOverGUI() then
                local currentPos = Vector2.new(mouse.X, mouse.Y)
                if (currentPos - lastMousePos).Magnitude > 5 then
                    recordAction("move", {x = mouse.X, y = mouse.Y})
                    lastMousePos = currentPos
                end
            end
        end
    end)
    
    -- Сохраняем соединения для остановки
    recordingConnection.Release = releaseConnection
    recordingConnection.Mouse = mouseConnection
end

-- Остановка записи
function stopRecording()
    isRecording = false
    recordBtn.Text = "🔴 ЗАПИСЬ"
    recordBtn.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
    statusLabel.Text = "⏸ Запись остановлена"
    statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    
    if recordingConnection then
        if recordingConnection.Release then
            recordingConnection.Release:Disconnect()
        end
        if recordingConnection.Mouse then
            recordingConnection.Mouse:Disconnect()
        end
        recordingConnection:Disconnect()
        recordingConnection = nil
    end
    updateUI()
end

-- ===== ФУНКЦИИ ВОСПРОИЗВЕДЕНИЯ =====

-- Старт воспроизведения
function startPlayback()
    if #recordedActions == 0 then
        statusLabel.Text = "⚠️ Нет записанных действий!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
        task.wait(1)
        statusLabel.Text = "⏸ Ожидание"
        statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        return
    end
    
    if isRecording then
        stopRecording()
    end
    
    isPlaying = true
    playBtn.Text = "⏹ СТОП"
    playBtn.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
    statusLabel.Text = "▶ ВОСПРОИЗВЕДЕНИЕ..."
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    playIndex = 1
    playStartTime = tick()
    
    playbackConnection = RunService.Heartbeat:Connect(function()
        if not isPlaying then return end
        if playIndex > #recordedActions then
            stopPlayback()
            return
        end
        
        local currentTime = tick() - playStartTime
        local action = recordedActions[playIndex]
        
        if currentTime >= action.time then
            executeAction(action)
            playIndex = playIndex + 1
        end
    end)
end

-- Остановка воспроизведения
function stopPlayback()
    isPlaying = false
    if playbackConnection then
        playbackConnection:Disconnect()
        playbackConnection = nil
    end
    playBtn.Text = "▶ ВОСПР."
    playBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
    statusLabel.Text = "⏸ Воспроизведение остановлено"
    statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    updateUI()
end

-- Выполнение действия
function executeAction(action)
    if action.type == "click" then
        local pos = Vector2.new(action.data.x, action.data.y)
        local touch = {
            Id = 1,
            Position = pos,
            Delta = Vector2.new(0, 0),
            Pressure = 1
        }
        
        if isMobile then
            UserInputService:SendEvent(Enum.UserInputType.Touch, Enum.KeyCode.Unknown, true, false, touch)
            task.wait(0.02)
            UserInputService:SendEvent(Enum.UserInputType.Touch, Enum.KeyCode.Unknown, false, false, touch)
        else
            UserInputService:SendEvent(Enum.UserInputType.MouseButton1, Enum.KeyCode.Unknown, true, false, touch)
            task.wait(0.02)
            UserInputService:SendEvent(Enum.UserInputType.MouseButton1, Enum.KeyCode.Unknown, false, false, touch)
        end
        
    elseif action.type == "jump" then
        local character = player.Character
        if character and character:FindFirstChild("Humanoid") then
            character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
        
    elseif action.type == "key" then
        local keyMap = {
            W = Enum.KeyCode.W,
            A = Enum.KeyCode.A,
            S = Enum.KeyCode.S,
            D = Enum.KeyCode.D,
            Shift = Enum.KeyCode.LeftShift
