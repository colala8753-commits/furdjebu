-- Создание точки клика
local function createClickPoint(position)
    local point = Instance.new("Frame")
    point.Size = UDim2.new(0, 45, 0, 45)
    point.Position = UDim2.new(0, position.X - 22.5, 0, position.Y - 22.5)
    point.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
    point.BackgroundTransparency = 0.4
    point.BorderSizePixel = 2
    point.BorderColor3 = Color3.fromRGB(0, 150, 255)
    point.Parent = pointsContainer
    point.ZIndex = 999
    point.Active = true
    point.Draggable = true
    
    local pointCorner = Instance.new("UICorner")
    pointCorner.CornerRadius = UDim.new(1, 0)
    pointCorner.Parent = point
    
    -- Центр точки (клик)
    local center = Instance.new("Frame")
    center.Size = UDim2.new(0, 8, 0, 8)
    center.Position = UDim2.new(0.5, -4, 0.5, -4)
    center.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    center.BackgroundTransparency = 0
    center.BorderSizePixel = 0
    center.Parent = point
    
    local centerCorner = Instance.new("UICorner")
    centerCorner.CornerRadius = UDim.new(1, 0)
    centerCorner.Parent = center
    
    -- Номер точки
    local numberLabel = Instance.new("TextLabel")
    numberLabel.Size = UDim2.new(1, 0, 1, 0)
    numberLabel.Text = tostring(#clickPoints)
    numberLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    numberLabel.TextSize = 14
    numberLabel.Font = Enum.Font.GothamBold
    numberLabel.BackgroundTransparency = 1
    numberLabel.Parent = point
    
    table.insert(pointObjects, point)
    return point
end

-- Добавление точки клика
local function addClickPoint()
    local pos = Vector2.new(mouse.X, mouse.Y)
    -- Проверяем, не слишком близко к существующим точкам
    for _, p in ipairs(clickPoints) do
        if (p - pos).Magnitude < 30 then
            return
        end
    end
    table.insert(clickPoints, pos)
    createClickPoint(pos)
    updateInfo()
end

-- Удаление последней точки
local function removeLastPoint()
    if #clickPoints > 0 then
        table.remove(clickPoints)
        local obj = table.remove(pointObjects)
        if obj then obj:Destroy() end
        updateInfo()
    end
end

-- Обновление информации
local function updateInfo()
    infoLabel.Text = tostring(#clickPoints)
end

-- ===== ОСНОВНАЯ ЛОГИКА КЛИКЕРА =====

-- Эмуляция клика
local function emulateClick(pos)
    if isMobile then
        local touch = {
            Id = 1,
            Position = pos,
            Delta = Vector2.new(0, 0),
            Pressure = 1
        }
        TouchInputService:SendEvent(Enum.UserInputType.Touch, Enum.KeyCode.Unknown, true, false, touch)
        wait(0.02)
        TouchInputService:SendEvent(Enum.UserInputType.Touch, Enum.KeyCode.Unknown, false, false, touch)
    else
        local touch = {
            Id = 1,
            Position = pos,
            Delta = Vector2.new(0, 0),
            Pressure = 1
        }
        TouchInputService:SendEvent(Enum.UserInputType.MouseButton1, Enum.KeyCode.Unknown, true, false, touch)
        wait(0.02)
        TouchInputService:SendEvent(Enum.UserInputType.MouseButton1, Enum.KeyCode.Unknown, false, false, touch)
    end
end

-- Запуск кликера
local function startClicker()
    if isRunning then return end
    if #clickPoints == 0 then
        showNotification("⚠️ Добавьте точки клика!", Color3.fromRGB(200, 150, 40))
        return
    end
    isRunning = true
    toggleBtn.Text = "⏹"
    toggleBtn.BackgroundColor3 = Color3.fromRGB(220, 40, 40)
    currentPointIndex = 1
    holdingDirection = 1
    
    clickerConnection = RunService.Heartbeat:Connect(function()
        if not isRunning then return end
        if #clickPoints == 0 then return end
        
        local currentPos = clickPoints[currentPointIndex]
        if currentPos then
            if isHolding then
                local targetPos = currentPos + Vector2.new(0, 30 * holdingDirection)
                emulateClick(targetPos)
                holdingDirection = holdingDirection * -1
                wait(0.15)
            else
                emulateClick(currentPos)
            end
        end
        
        currentPointIndex = currentPointIndex + 1
        if currentPointIndex > #clickPoints then
            currentPointIndex = 1
        end
        
        wait(0.05)
    end)
end

-- Остановка кликера
local function stopClicker()
    isRunning = false
    if clickerConnection then
        clickerConnection:Disconnect()
        clickerConnection = nil
    end
    toggleBtn.Text = "▶"
    toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
end

-- Переключение кликера
local function toggleClicker()
    if isRunning then
        stopClicker()
    else
        startClicker()
    end
end

